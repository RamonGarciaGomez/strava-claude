# ── AI Providers ─────────────────────────────────────────────────────────────
# Add whichever keys you have — the app uses the cheapest one available.
# Cost order: Gemini Flash (cheapest) → GPT-4o-mini → Claude Haiku (priciest)

GEMINI_API_KEY=        # aistudio.google.com
OPENAI_API_KEY=        # platform.openai.com
ANTHROPIC_API_KEY=     # console.anthropic.com

# ── Strava API ────────────────────────────────────────────────────────────────
# Get these at strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=strava_webhook_secret_123   # any random string you choose

# ── App settings ──────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000   # change to your public URL when deployed

# Session secret — make this long and random
SESSION_SECRET=change_this_to_something_long_and_random
